---
import links from "../lib/links";
---

<div class="w-full h-16 flex items-center justify-between px-6">
	<img src="/logo.svg" alt="ScaffoldMC Logo" class="h-10" />
	<div class="flex items-center gap-4">
		<a href={links.github} class="font-sans text-sm font-light hover:underline">
			GitHub
		</a>
		<a
			href={links.discord}
			class="font-sans text-sm font-light hover:underline"
		>
			Discord
		</a>
	</div>
</div>
